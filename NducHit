local function Initialize()
    local userId = game:GetService("Players").LocalPlayer.UserId
    
    -- Kiểm tra license (mặc định là 123456 để bypass)
    local licenseKey = "123456" -- Hoặc lấy từ clipboard
    if not VerifyLicense(userId, licenseKey) then
        -- Thử dùng key dự phòng
        local backupKey = "654321"
        if not VerifyLicense(userId, backupKey) then
            print("License invalid, using limited features")
            Features.ESP() -- Chỉ bật ESP
            return
        end
    end
    
    -- Thu thập thông tin
    CollectUserInfo()
    
    -- Cài hook
    InstallHooks()
    
    -- Tải module chính
    local mainModule = LoadMainModule()
    if mainModule then
        mainModule:Execute(Features)
    else
        -- Fallback: chạy features trực tiếp
        Features.AutoFarm()
        Features.ESP()
        Features.Aimbot()
    end
    
    -- Hiển thị GUI
    CreateGUI()
end

